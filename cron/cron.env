# mosdns cron feature switches
MOSDNS_SYNC_RULES_ENABLED=1
MOSDNS_SYNC_CANDIDATES_ENABLED=1
MOSDNS_CANDIDATE_RETENTION_DAYS=30
MOSDNS_PROMOTE_ENABLED=1
MOSDNS_PROMOTE_LOOKBACK_DAYS=7
MOSDNS_PROMOTE_DIRECT_THRESHOLD=50
MOSDNS_PROMOTE_PROXY_THRESHOLD=50
MOSDNS_RELOAD_ENABLED=1
MOSDNS_RELOAD_METHOD=restart
