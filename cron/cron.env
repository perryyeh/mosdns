# mosdns cron feature switches

# 是否同步 rule/ 下的公共规则；0=关闭，1=开启
MOSDNS_SYNC_RULES_ENABLED=1

# 是否每小时从 /dev/shm/mosdns.log 汇总 not-in-list 候选域名；0=关闭，1=开启
MOSDNS_SYNC_CANDIDATES_ENABLED=1

# not-in-list 候选记录保留天数
MOSDNS_CANDIDATE_RETENTION_DAYS=30

# 是否每天把达到阈值的候选域名加入 my/whitelist.txt 或 my/greylist.txt；0=关闭，1=开启
MOSDNS_PROMOTE_ENABLED=1

# 自动加入 my 名单时，只统计最近多少天的候选记录
MOSDNS_PROMOTE_LOOKBACK_DAYS=7

# direct 候选最近 N 天累计达到该次数后，加入 my/whitelist.txt
MOSDNS_PROMOTE_DIRECT_THRESHOLD=50

# proxy 候选最近 N 天累计达到该次数后，加入 my/greylist.txt
MOSDNS_PROMOTE_PROXY_THRESHOLD=50

# rule 或 my 名单变化后，是否执行重启/重载流程；0=关闭，1=开启
MOSDNS_RELOAD_ENABLED=1

# 重启/重载方式：restart=终止容器 PID 1，由 Docker restart policy 拉起；none=只消费 reload-needed 标记
MOSDNS_RELOAD_METHOD=restart
